{
  "name": "subscription-payments-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "api": "json-server --watch mock-server/db.json --port 3000",
    "api:prod": "json-server --host 0.0.0.0 --port ${PORT:-3000} mock-server/db.json",
    "dev": "concurrently \"npm run api\" \"npm run start\"",
    "build": "ng build --configuration production",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "e2e": "playwright test",
    "lint": "ng lint && stylelint \"src/**/*.scss\"",
    "format": "prettier --write \"{src,e2e,docs,mock-server}/**/*.{ts,html,scss,json,md}\" \"*.{json,md,js}\""
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngrx/effects": "^21.0.0",
    "@ngrx/store": "^21.0.0",
    "@ngrx/store-devtools": "^21.0.0",
    "@taiga-ui/core": "^4.0.0",
    "@taiga-ui/kit": "^4.0.0",
    "@taiga-ui/layout": "^4.0.0",
    "concurrently": "^9.1.2",
    "json-server": "^1.0.0-beta.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@playwright/test": "^1.51.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "jest-preset-angular": "^16.1.4",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.15.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.9.0"
  }
}
